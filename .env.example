# Copy this file to .env and fill in your values.
# .env is excluded from version control (see .gitignore).

# -----------------------------------------------
# OpenAI Configuration (required for AI features)
# -----------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------
# MCP Server Configuration (sysmod_mcp_server.py)
# -----------------------------------------------

# URL of the running SYSMOD Flask server
FLASK_BASE_URL=http://localhost:5000

# Default SysML v2 connection context
# Set these so the MCP tools work without requiring parameters on every call.
SYSML_SERVER_URL=http://localhost:9000
SYSML_PROJECT_ID=
SYSML_COMMIT_ID=
SYSML_SYSMOD_PROJECT_ID=

